{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "FRONTEND/dist",
  "env": {
    "VITE_API_BASE_URL": "/api/v1"
  },
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}